body{
  font-family: Arial;
  text-align: center;
  background: #eef2ff;
}

h1{
  color: #333;
}

#question{
  font-size: 24px;
  margin: 20px;
}

input{
  padding: 8px;
  font-size: 16px;
}

button{
  padding: 8px 15px;
  font-size: 16px;
  background: #4CAF50;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover{
  background: #45a049;
}

#result{
  margin-top: 15px;
  font-weight: bold;
}
